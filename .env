# ─────────────────────────────────────────────────────────────────────────────
# VokCG Web — Shared base environment variables
# Loaded by ALL apps in ALL environments.
# Safe to commit — no secrets here.
# ─────────────────────────────────────────────────────────────────────────────

# App identity
NEXT_PUBLIC_APP_NAME=VokCGStudio
NEXT_PUBLIC_APP_SUBTITLE=AI Video Generator

# Storage key namespace prefix (keeps localStorage keys isolated per deploy)
NEXT_PUBLIC_STORAGE_NAMESPACE=vokcg

# Railway production API — used by .env.production in each app
# Override per-app or with .env.local for a different backend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8888
