# ─────────────────────────────────────────────────────────────────────────────
# VokCG Web — Environment Variables Reference
#
# This project uses a layered env system inspired by vue-vben-admin:
#
#   .env                  Shared base (all envs, both apps) — COMMITTED
#   .env.development      Dev overrides per app              — COMMITTED
#   .env.production       Prod overrides per app             — COMMITTED
#   .env.local            Machine-local overrides            — GITIGNORED ⚠️
#   .env.development.local  Dev machine-local overrides      — GITIGNORED ⚠️
#
# Load priority (highest → lowest):
#   .env.local > .env.development/.env.production > .env
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Shared (root .env) ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=VokCGStudio
NEXT_PUBLIC_APP_SUBTITLE=AI Video Generator
# Optional — longer SEO description; falls back to APP_SUBTITLE + feature summary
# NEXT_PUBLIC_APP_DESCRIPTION=VokCGStudio is an AI video generator for avatars, voice, and scripts.
# Public URL for canonical links and Open Graph (web-user)
# NEXT_PUBLIC_STUDIO_URL=https://studio.example.com
NEXT_PUBLIC_STORAGE_NAMESPACE=vokcg

# ── Per-app (apps/web-admin/.env or apps/web-user/.env) ─────────────────────
NEXT_PUBLIC_APP_TITLE=VokCGStudio Admin   # or "VokCGStudio" for web-user
NEXT_PUBLIC_APP_ROLE=admin                # or "user" for web-user
PORT=3001                                 # or 3000 for web-user

# ── Development (apps/*/. env.development) ───────────────────────────────────
# Use Next.js proxy to avoid CORS in dev (baseURL = "")
NEXT_PUBLIC_API_BASE_URL=
API_PROXY_URL=http://127.0.0.1:8888

# ── Production (apps/*/.env.production) ─────────────────────────────────────
# Direct call to Railway — no proxy needed
NEXT_PUBLIC_API_BASE_URL=https://vokcg-studio-api.up.railway.app

# ── Local override (.env.local — NEVER COMMIT) ───────────────────────────────
# Copy only what you need to override:
# NEXT_PUBLIC_API_BASE_URL=https://vokcg-studio-api.up.railway.app  # use Railway in dev
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8888                    # use custom local backend
# API_PROXY_URL=http://my-backend:8888                              # custom proxy target
